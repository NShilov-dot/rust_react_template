DATABASE_URL=postgres://app:app@localhost:5432/app
REDIS_URL=redis://localhost:6379
BIND_ADDR=0.0.0.0:8080
DB_MAX_CONNECTIONS=10
RUST_LOG=info,api=debug,tower_http=info

# Auth — REQUIRED, must be >= 32 bytes.
# Generate locally with:  openssl rand -base64 48
JWT_SECRET=replace-me-with-output-of-openssl-rand-base64-48
JWT_ISSUER=rust-react-api
ACCESS_TTL_SECS=900           # 15 min
REFRESH_TTL_SECS=2592000      # 30 days
